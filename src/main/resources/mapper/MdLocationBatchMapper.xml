<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.MdLocationBatchMapper">

    <resultMap id="MdLocationBatchVOMap" type="com.example.demo.vo.MdLocationBatchVO">
        <result property="batchId" column="batch_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="status" column="status"/>
        <result property="originalFilename" column="original_filename"/>
        <result property="message" column="message"/>
    </resultMap>

    <resultMap id="MdLocationBatchMap" type="com.example.demo.entity.MdLocationBatch">
        <result property="batchId" column="batch_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="status" column="status"/>
        <result property="originalFilename" column="original_filename"/>
        <result property="message" column="message"/>
    </resultMap>

    <!-- 根据条件查询批次列表 -->
    <select id="selectByCondition" resultMap="MdLocationBatchVOMap">
        SELECT
            batch_id,
            create_time,
            update_time,
            status,
            original_filename,
            message
        FROM haosen_project.dbo.md_location_batch
        <where>
            <if test="condition.batchId != null and condition.batchId != ''">
                AND batch_id LIKE '%' + #{condition.batchId} + '%'
            </if>
            <if test="condition.status != null">
                AND status = #{condition.status}
            </if>
            <if test="condition.startTime != null and condition.startTime != ''">
                AND create_time &gt;= CAST(#{condition.startTime} AS DATETIME)
            </if>
            <if test="condition.endTime != null and condition.endTime != ''">
                AND create_time &lt;= DATEADD(day, 1, CAST(#{condition.endTime} AS DATETIME))
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 插入批次记录 -->
    <insert id="insert" parameterType="com.example.demo.entity.MdLocationBatch">
        INSERT INTO haosen_project.dbo.md_location_batch (
            batch_id,
            create_time,
            update_time,
            status,
            original_filename,
            message
        ) VALUES (
            #{batchId},
            GETDATE(),
            GETDATE(),
            #{status},
            #{originalFilename},
            #{message}
        )
    </insert>

    <!-- 根据批次 ID 查询批次 -->
    <select id="selectByBatchId" resultMap="MdLocationBatchMap">
        SELECT * FROM haosen_project.dbo.md_location_batch WHERE batch_id = #{batchId}
    </select>

    <!-- 更新批次状态 -->
    <update id="updateStatus">
        UPDATE haosen_project.dbo.md_location_batch
        SET status = #{status},
            update_time = GETDATE(),
            message = #{message}
        WHERE batch_id = #{batchId}
    </update>

    <!-- 根据批次 ID 删除批次 -->
    <delete id="deleteByBatchId">
        DELETE FROM haosen_project.dbo.md_location_batch WHERE batch_id = #{batchId}
    </delete>

</mapper>
